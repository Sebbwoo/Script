-- Faithful Fakeout Function (based on original IY logic)
local function executeFakeout()
	local character = player.Character
	if not character then return end
	
	local root = character:FindFirstChild("HumanoidRootPart") or 
	             character:FindFirstChild("UpperTorso") or 
	             character:FindFirstChild("Torso")
	if not root then return end

	local oldPos = root.CFrame
	local originalHeight = workspace.FallenPartsDestroyHeight

	-- Fakeout logic
	workspace.FallenPartsDestroyHeight = 0/1/0        -- NaN trick (infinity)
	root.CFrame = CFrame.new(0, -10000, 0)            -- Drop far down

	task.wait(1.15)

	-- Return to original position
	root.CFrame = oldPos
	workspace.FallenPartsDestroyHeight = originalHeight

	print("✅ Fakeout executed")
end

-- Click handler
circle.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		
		-- Click animation
		TweenService:Create(circle, TweenInfo.new(0.1), {Size = UDim2.new(0, 74, 0, 74)}):Play()
		task.wait(0.1)
		TweenService:Create(circle, TweenInfo.new(0.15), {Size = UDim2.new(0, 85, 0, 85)}):Play()

		executeFakeout()
	end
end)

