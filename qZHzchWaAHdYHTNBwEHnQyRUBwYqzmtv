-- === UI FUNCTIONS ===
local function updateToggleUI(toggleFrame, knob, on)
    if on then
        toggleFrame.BackgroundColor3 = Color3.fromRGB(0, 190, 110)
        TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(1, -14, 0.5, -6)}):Play()
    else
        toggleFrame.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        TweenService:Create(knob, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Position = UDim2.new(0, 2, 0.5, -6)}):Play()
    end
end

local function populatePlayerList()
    for _, child in ipairs(PlayerListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local players = Players:GetPlayers()
    local sorted = {}
    for _, p in ipairs(players) do
        if p ~= LocalPlayer then table.insert(sorted, p) end
    end
    table.sort(sorted, function(a,b) return a.Name < b.Name end)
    
    local yOffset = 0
    local buttonHeight = 18
    for _, p in ipairs(sorted) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -4, 0, buttonHeight)
        btn.Position = UDim2.new(0, 2, 0, yOffset)
        btn.BackgroundColor3 = Color3.fromRGB(45, 46, 47)
        btn.Text = p.Name
        btn.TextColor3 = Color3.fromRGB(220, 220, 220)
        btn.TextSize = 10
        btn.Font = Enum.Font.GothamSemibold
        btn.BorderSizePixel = 0
        btn.ZIndex = 10
        btn.Parent = PlayerListFrame
        
        btn.MouseButton1Click:Connect(function()
            selectedPlayer = p
            DropdownButton.Text = p.Name
            dropdownOpen = false
            PlayerListFrame.Visible = false
        end)
        
        yOffset = yOffset + buttonHeight + 2
    end
    PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, yOffset)
end

local function refreshPlayerList()
    populatePlayerList()
    TweenService:Create(RefreshButton, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Rotation = 360}):Play()
end

DropdownButton.MouseButton1Click:Connect(function()
    dropdownOpen = not dropdownOpen
    PlayerListFrame.Visible = dropdownOpen
    if dropdownOpen then populatePlayerList() end
end)

RefreshButton.MouseButton1Click:Connect(refreshPlayerList)

-- === TELEPORT FUNCTIONS ===
local function teleportToTarget()
    if not selectedPlayer then
        print("No player selected.")
        return
    end
    local targetChar = selectedPlayer.Character
    if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then
        print("Target has no valid character.")
        return
    end
    local targetHRP = targetChar.HumanoidRootPart
    local localChar = LocalPlayer.Character
    if not localChar or not localChar:FindFirstChild("HumanoidRootPart") then
        print("You have no valid character.")
        return
    end
    local localHRP = localChar.HumanoidRootPart
    
    if not localChar.PrimaryPart then
        localChar.PrimaryPart = localHRP
    end
    
    pcall(function()
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
        if localHRP:IsA("BasePart") then
            localHRP.Velocity = Vector3.new(0,0,0)
            localHRP.RotVelocity = Vector3.new(0,0,0)
        end
    end)
    
    local targetCF = targetHRP.CFrame + Vector3.new(0, 2, 0)
    for i = 1, 5 do
        localChar:SetPrimaryPartCFrame(targetCF)
        task.wait(0.03)
    end
    
    print("Teleported to " .. selectedPlayer.Name)
end

local function bringTargetToMe()
    if not selectedPlayer then
        print("No player selected.")
        return
    end
    local targetChar = selectedPlayer.Character
    if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then
        print("Target has no valid character.")
        return
    end
    local localChar = LocalPlayer.Character
    if not localChar or not localChar:FindFirstChild("HumanoidRootPart") then
        print("You have no valid character.")
        return
    end
    
    local targetHRP = targetChar.HumanoidRootPart
    local localHRP = localChar.HumanoidRootPart
    
    if not targetChar.PrimaryPart then
        targetChar.PrimaryPart = targetHRP
    end
    
    targetChar:SetPrimaryPartCFrame(localHRP.CFrame + Vector3.new(0, 2, 0))
    print("Brought " .. selectedPlayer.Name .. " to you (client-side visual only).")
end

