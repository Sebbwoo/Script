-- === BYPASS LOGIC ===
local function forceAliveState()
    if not bypassActive or not character then return end
    pcall(function()
        character:SetAttribute("Dead", false)
        if humanoid then
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
            humanoid.Health = humanoid.MaxHealth
            humanoid.Health = humanoid.Health - 0.001
            task.wait()
            humanoid.Health = humanoid.MaxHealth
        end
    end)
end

local function fixHealthBar()
    if not bypassActive then return end
    pcall(function()
        local head = character:FindFirstChild("Head")
        if head then
            local hb = head:FindFirstChild("Healthbar") or character:FindFirstChild("Healthbar")
            if hb and hb:FindFirstChild("BarFrame") then
                local bar = hb.BarFrame:FindFirstChild("Bar")
                if bar then bar.Size = UDim2.new(1,0,1,0) end
            end
        end
    end)
end

local function antiUnequip()
    if not bypassActive or not currentTool then return end
    pcall(function()
        if currentTool.Parent ~= character then
            humanoid:EquipTool(currentTool)
        end
    end)
end

-- === AUTO REVIVE LOGIC ===
local function findRevivePrompt(char)
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Name == "RevivePrompt" then
            return obj
        end
    end
    return nil
end

local function autoReviveLoop()
    if not autoReviveActive then return end
    if tick() - lastReviveFire < 0.8 then return end

    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    local myPos = myChar.HumanoidRootPart.Position

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local target = plr.Character
            local root = target:FindFirstChild("HumanoidRootPart")
            local hum = target:FindFirstChild("Humanoid")

            if root and hum and hum.Health > 0 and hum.Health < 40 then
                if (myPos - root.Position).Magnitude <= REVIVE_RANGE then
                    local prompt = findRevivePrompt(target)
                    if prompt and prompt.Enabled then
                        local fired = false

                        local trigger = prompt:FindFirstChild("Trigger2")
                        if trigger and trigger:IsA("RemoteEvent") then
                            trigger:FireServer(nil)
                            fired = true
                        end

                        if not fired then
                            local remote = prompt:FindFirstChildOfClass("RemoteEvent") or
                                           prompt.Parent:FindFirstChildOfClass("RemoteEvent")
                            if remote then
                                remote:FireServer(nil)
                                fired = true
                            end
                        end

                        if not fired then
                            pcall(function()
                                prompt:FireServer(nil)
                                fired = true
                            end)
                        end

                        if fired then
                            print("✅ Revived " .. plr.Name)
                            lastReviveFire = tick()
                            return
                        end
                    end
                end
            end
        end
    end
end

-- === METATABLE HOOK ===
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    if not bypassActive then return oldNamecall(self, ...) end
    if getnamecallmethod() == "GetAttribute" and ({...})[1] == "Dead" then
        return false
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

-- === MAIN LOOP ===
