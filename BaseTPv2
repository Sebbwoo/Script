-- Functions
TeleportButton.MouseButton1Click:Connect(tpDown)

local listeningForKey = false

KeybindButton.MouseButton1Click:Connect(function()
    listeningForKey = true
    KeybindButton.Text = "Press key or ESC for None"
    KeybindButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if listeningForKey then
        if input.KeyCode == Enum.KeyCode.Escape then
            currentKeybind = nil
            listeningForKey = false
            KeybindButton.Text = "Keybind: None"
            KeybindButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        elseif input.KeyCode ~= Enum.KeyCode.Unknown then
            currentKeybind = input.KeyCode
            listeningForKey = false
            KeybindButton.Text = "Keybind: " .. currentKeybind.Name
            KeybindButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        end
        return
    end

    -- Normal keybind trigger
    if currentKeybind and input.KeyCode == currentKeybind then
        tpDown()
    end
end)
