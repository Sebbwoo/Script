local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local tpDownActive = false
local currentKeybind = Enum.KeyCode.F  -- Default

local function myRootPart()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
end

local function tpDown()
    if tpDownActive then return end
    local hrp = myRootPart()
    if not hrp then return end

    tpDownActive = true
    task.spawn(function()
        local parts = {}
        local DISTANCE = 15
        local STEP_SIZE = 3
        local STEP_DELAY = 0.03

        for _, p in ipairs(LocalPlayer.Character:GetDescendants()) do
            if p:IsA("BasePart") then
                table.insert(parts, {part = p, canCollide = p.CanCollide})
                p.CanCollide = false
            end
        end

        local startCf = hrp.CFrame
        local steps = math.ceil(DISTANCE / STEP_SIZE)

        for step = 1, steps do
            if not hrp.Parent then break end
            local offset = math.min(step * STEP_SIZE, DISTANCE)
            hrp.CFrame = startCf * CFrame.new(0, -offset, 0)
            task.wait(STEP_DELAY)
        end

        for _, entry in ipairs(parts) do
            if entry.part and entry.part.Parent then
                entry.part.CanCollide = entry.canCollide
            end
        end

        tpDownActive = false
    end)
end

