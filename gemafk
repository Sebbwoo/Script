local function getGemCount()
    local ok, result = pcall(function()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            local gemDisplay = playerGui:FindFirstChild("GemDisplay", true)
            if gemDisplay then
                local countLabel = gemDisplay:FindFirstChild("Count", true)
                if countLabel and countLabel:IsA("TextLabel") then
                    local raw = tostring(countLabel.Text or "0")
                    local cleaned = raw:gsub("[^%d]", "")
                    return tonumber(cleaned) or 0
                end
            end
        end
        local ls = LocalPlayer:FindFirstChild("leaderstats")
        if ls then
            for _, v in ipairs(ls:GetChildren()) do
                if (v:IsA("IntValue") or v:IsA("NumberValue")) and string.lower(v.Name):find("gem") then
                    return v.Value
                end
            end
        end
        return LocalPlayer:GetAttribute("Gems") or LocalPlayer:GetAttribute("Gem") or 0
    end)
    return ok and result or 0
end

-- ==================== LOGGING ====================
local function logResult(timeTaken, gemCollected)
    pcall(function()
        local ts = os.date("%Y-%m-%d %H:%M:%S")
        local status = gemCollected and "GEM_COLLECTED" or "NO_GEM_DETECTED"
        local line = string.format("[%s] Cycle: %.2fs | %s\n", ts, timeTaken, status)
        local filename = "GemFarm_Times.txt"
        local existing = isfile(filename) and readfile(filename) or ""
        writefile(filename, existing .. line)
        print("📄 Logged to GemFarm_Times.txt → " .. status)
    end)
end

