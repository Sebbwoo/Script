local function StartPermanentNoclip()
    local noclipConn
    local function enableNoclip()
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = RunService.Stepped:Connect(function()
            if not PermanentNoclipEnabled then return end
            local character = LocalPlayer.Character
            if character then
                for _, v in ipairs(character:GetDescendants()) do
                    if v:IsA("BasePart") and v.CanCollide then v.CanCollide = false end
                end
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
            end
        end)
    end
    enableNoclip()
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(0.1)
        enableNoclip()
    end)
end
StartPermanentNoclip()

local spawnReferencePos = nil

local function getGeneratorPosition()
    if cachedGenerator then return cachedGenerator end
    if MapFolder and MapFolder:FindFirstChild("Tiles") then
        for _, tile in ipairs(MapFolder.Tiles:GetChildren()) do
            if tile.Name == "Generator" or tile:FindFirstChild("Generator") then
                cachedGenerator = tile:GetPivot().Position
                return cachedGenerator
            end
        end
    end
    local gen = Workspace:FindFirstChild("Generator", true)
    if gen then
        cachedGenerator = gen:GetPivot().Position
        return cachedGenerator
    end
    return nil
end

local function getClosestPowerPlant(currentPos)
    if not spawnReferencePos then
        spawnReferencePos = currentPos
    end

    local bestBox, bestPos = nil, nil
    local bestDist = math.huge
    local MAX_SPAWN_DIST = 900

    if MapFolder and MapFolder:FindFirstChild("Tiles") then
        for _, tile in ipairs(MapFolder.Tiles:GetChildren()) do
            if tile.Name == "Power Plant" then
                local box = tile:FindFirstChild("Power Box")
                if box then
                    local pos = box:GetPivot().Position
                    local distToCurrent = (currentPos - pos).Magnitude
                    local distFromSpawn = (spawnReferencePos - pos).Magnitude

                    if distFromSpawn <= MAX_SPAWN_DIST and distToCurrent < bestDist then
                        bestDist = distToCurrent
                        bestBox, bestPos = box, pos
                    end
                end
            end
        end
    end

    if not bestBox then
        bestDist = math.huge
        if MapFolder and MapFolder:FindFirstChild("Tiles") then
            for _, tile in ipairs(MapFolder.Tiles:GetChildren()) do
                if tile.Name == "Power Plant" then
                    local box = tile:FindFirstChild("Power Box")
                    if box then
                        local pos = box:GetPivot().Position
                        local distToCurrent = (currentPos - pos).Magnitude
                        if distToCurrent < bestDist then
                            bestDist = distToCurrent
                            bestBox, bestPos = box, pos
                        end
                    end
                end
            end
        end
    end

    return bestBox, bestPos
end

local function getBestFuelTowardTarget(currentPos, targetPos)
    local bestTarget, bestScore = nil, -math.huge
    local dirToTarget = (targetPos - currentPos).Unit
    for _, item in ipairs(DroppedItems:GetChildren()) do
        if item.Name == "Fuel" and not excludeFuel[item] then
            local fuelPos = item:GetPivot().Position
            if (fuelPos.Y - currentPos.Y) > 2 then excludeFuel[item] = true; continue end
            local dist = (currentPos - fuelPos).Magnitude
            local alignment = (fuelPos - currentPos).Unit:Dot(dirToTarget)
            local score = (alignment * 95) - (dist * 0.75)
            if score > bestScore then bestScore, bestTarget = score, item end
        end
    end
    return bestTarget
end

local function getClosestFuelPosition(currentPos)
    local bestTarget, shortest = nil, math.huge
    for _, item in ipairs(DroppedItems:GetChildren()) do
        if item.Name == "Fuel" and not excludeFuel[item] then
            local fuelPos = item:GetPivot().Position
            local dist = (currentPos - fuelPos).Magnitude
            local heightDiff = fuelPos.Y - currentPos.Y
            if heightDiff <= 2 and dist < shortest then
                shortest, bestTarget = dist, item
            elseif heightDiff > 2 then
                excludeFuel[item] = true
            end
        end
    end
    return bestTarget
end

local function FuelTeleport(hrp, targetFuel)
    local genPos = getGeneratorPosition()
    if not hrp or not targetFuel or not genPos then return end
    local fuelUnion = targetFuel:FindFirstChild("Union") or targetFuel.PrimaryPart
    local itemDrag = targetFuel:FindFirstChild("ItemDrag")
    local networkRemote = itemDrag and itemDrag:FindFirstChild("RequestNetworkOwnership")
    if fuelUnion and networkRemote then
        pcall(function() networkRemote:FireServer(fuelUnion) end)
        task.wait(0.12)
        pcall(function() targetFuel:PivotTo(CFrame.new(genPos) + Vector3.new(0, 1, 0)) end)
        task.wait(0.15)
    end
end
