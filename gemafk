local function adaptiveCrawlTo(targetPos, hrp, character)
    local finalTarget = targetPos + Vector3.new(0, 2.8, 0)
    local FAST_SPEED, SLOW_SPEED = 295, 28.5
    local BURST_TIME, RECOVERY_TIME = 1.8, 0.65
    local STEP_DISTANCE, STUCK_THRESHOLD, RUBBERBAND_THRESHOLD = 0.28, 0.11, 0.20
    local CORRECTIVE_HOP = 1.6

    local lastBurstTime = 0
    local targetY = hrp.Position.Y
    local lastPos = hrp.Position
    local stuckCounter, yUpdateCounter = 0, 0
    local rubberbandStreak = 0

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {character}

    local function multiRayProbe(origin, dir, dist)
        local hits = 0
        local directions = {
            dir,
            dir + Vector3.new(0.6, 0, 0),
            dir + Vector3.new(-0.6, 0, 0),
            dir + Vector3.new(0, 0.8, 0),
            dir + Vector3.new(0, -0.6, 0)
        }
        for _, d in ipairs(directions) do
            local r = Workspace:Raycast(origin, d.Unit * dist, rayParams)
            if r and r.Instance.CanCollide then hits += 1 end
        end
        return hits
    end

    while true do
        if not hrp or not hrp.Parent then break end
        local currentPos = hrp.Position
        local remaining = Vector3.new(finalTarget.X, targetY, finalTarget.Z) - currentPos

        if remaining.Magnitude <= 2.2 then
            hrp.CFrame = CFrame.new(finalTarget)
            break
        end

        local moved = (currentPos - lastPos).Magnitude
        stuckCounter = (moved < STUCK_THRESHOLD) and stuckCounter + 1 or 0
        lastPos = currentPos

        if stuckCounter >= 3 then
            lastBurstTime = os.clock() - BURST_TIME - 0.35
            stuckCounter = 0
            hrp.CFrame = hrp.CFrame + Vector3.new(0, 2.2, 0)
            task.wait(0.10)
        end

        yUpdateCounter += 1
        if yUpdateCounter >= 8 then
            local desiredY = hrp.Position.Y
            targetY = targetY + (desiredY - targetY) * 0.35
            yUpdateCounter = 0
        end

        local now = os.clock()
        local timeSince = now - lastBurstTime
        if timeSince > (BURST_TIME + RECOVERY_TIME) then lastBurstTime = now end
        local isBurst = timeSince < BURST_TIME
        local speed = isBurst and FAST_SPEED or SLOW_SPEED
        local step = isBurst and 1.32 or STEP_DISTANCE

        local dir = remaining.Unit

        local probeHits = multiRayProbe(currentPos + Vector3.new(0, 1.2, 0), dir, 6.5)
        if probeHits >= 2 then
            lastBurstTime = now - BURST_TIME - 0.25
        end

        local jitter = Vector3.new(
            (math.random() - 0.5) * 0.08,
            0,
            (math.random() - 0.5) * 0.08
        )
        dir = (dir + jitter).Unit

        local delay = step / speed
        local nextPos = currentPos + (dir * step)
        local desiredCFrame = CFrame.new(Vector3.new(nextPos.X, targetY, nextPos.Z))

        hrp.CFrame = desiredCFrame
        if hrp.AssemblyLinearVelocity then
            hrp.AssemblyLinearVelocity = Vector3.zero
        end

        task.wait(delay * 0.52)

        local actualDelta = (hrp.Position - currentPos).Magnitude
        if actualDelta < RUBBERBAND_THRESHOLD then
            rubberbandStreak += 1
            lastBurstTime = now - BURST_TIME - 0.45

            if rubberbandStreak >= 2 then
                local perp = Vector3.new(-dir.Z, 0, dir.X) * (math.random() > 0.5 and 1 or -1)
                hrp.CFrame = hrp.CFrame + Vector3.new(0, CORRECTIVE_HOP + math.random()*0.4, 0) + (perp * 0.8)
                task.wait(0.09)
                rubberbandStreak = 0
            end
        else
            rubberbandStreak = 0
        end

        task.wait(delay * 0.42)
    end
end

