local function runPipeline()
    print("Starting optimized gem farm cycle (v14.5)...")
    excludeFuel = {}

    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")

    -- Fuel 1
    local ppBox, ppPos = getClosestPowerPlant(hrp.Position)
    local fuel1 = ppPos and getBestFuelTowardTarget(hrp.Position, ppPos) or getClosestFuelPosition(hrp.Position)
    if fuel1 then
        adaptiveCrawlTo(fuel1:GetPivot().Position, hrp, character)
        task.wait(0.28)
        FuelTeleport(hrp, fuel1)
        task.wait(0.42)
        TimerHUD.SplitFuel1()
    end

    -- Fuel 2
    ppBox, ppPos = getClosestPowerPlant(hrp.Position)
    local fuel2 = ppPos and getBestFuelTowardTarget(hrp.Position, ppPos) or getClosestFuelPosition(hrp.Position)
    if fuel2 then
        adaptiveCrawlTo(fuel2:GetPivot().Position, hrp, character)
        task.wait(0.28)
        FuelTeleport(hrp, fuel2)
        task.wait(0.42)
        TimerHUD.SplitFuel2()
    end

    -- Power Plant + GEM DETECTION
    ppBox, ppPos = getClosestPowerPlant(hrp.Position)
    local gemBefore = getGemCount()
    if ppBox and ppPos then
        adaptiveCrawlTo(ppPos, hrp, character)
        task.wait(0.42)
        if (hrp.Position - ppPos).Magnitude < 18 then
            local prompt = ppBox:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                for i = 1, 3 do
                    pcall(function()
                        if fireproximityprompt then
                            fireproximityprompt(prompt)
                        else
                            prompt:InputHoldBegin()
                            task.wait((prompt.HoldDuration or 0.5) + 0.05)
                            prompt:InputHoldEnd()
                        end
                    end)
                    task.wait(0.1)
                end
            end
        end
        TimerHUD.SplitPowerPlant()
    end

    task.wait(1.8)
    local gemAfter = getGemCount()
    local gemCollected = (gemAfter > gemBefore)
    if not gemCollected then
        warn("[GemFarm] ⚠️ Power Plant did NOT award a gem this cycle!")
    else
        print("[GemFarm] ✅ Gem collected! (+" .. (gemAfter - gemBefore) .. ")")
    end

    task.wait(0.6)
    pcall(function()
        if VotePlayAgainRemote then VotePlayAgainRemote:FireServer() end
    end)

    local finalTime = TimerHUD.Stop()
    print(string.format("✅ Cycle finished in %.2f seconds", finalTime))
    logResult(finalTime, gemCollected)
end

runPipeline()

